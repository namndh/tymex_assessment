# Copy to .env and fill in. .env is gitignored; never commit real secrets.
# scripts/deploy.py and the churn-dbx-* CLIs read these values.

# ============================================================================
# LOCAL CHECK (no Databricks needed) — run pytest + a Spark-local pipeline here
# ============================================================================
CHURN_DBX_MODE=local
CHURN_DBX_LOCAL_ROOT=./_local
# Point at the raw case-study CSVs — download them into ./data first, see README
# "Get the data".
CHURN_DBX_RAW_DIR=./data

# ============================================================================
# DATABRICKS FREE EDITION (real deploy) — fill in to run scripts/deploy.py
# ============================================================================
# Workspace URL from signup, e.g. https://dbc-abc123.cloud.databricks.com
DATABRICKS_HOST=
# Personal Access Token: UI -> Settings -> Developer -> Access tokens -> Generate.
DATABRICKS_TOKEN=

# Unity Catalog storage (non-secret). Free Edition default catalog is "workspace".
CATALOG=workspace
SCHEMA=churn_dev
VOLUME=raw

# Bundle deploy target (dev | prod). Must match a target in databricks.yml.
TARGET=dev

# Raw-data source for the deploy `data` stage: a dir of CSVs, a zip, or an https URL
# to one, unzipped/downloaded then uploaded to the UC Volume. See README "Get the
# data". Defaults to the same ./data folder as the local check above.
#   Hosted: DATA_URL=https://example.com/customer360.zip
DATA_URL=./data
